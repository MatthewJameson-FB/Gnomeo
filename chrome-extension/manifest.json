{
  "manifest_version": 3,
  "name": "Gnomeo Review Layer",
  "version": "0.1.0",
  "description": "A calm review layer for ad platforms.",
  "action": {
    "default_title": "Open Gnomeo"
  },
  "permissions": ["storage", "tabs", "sidePanel"],
  "side_panel": {
    "default_path": "panel.html"
  },
  "host_permissions": [
    "https://www.gnomeo.nl/*",
    "https://gnomeo.nl/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://ads.google.com/*",
        "https://business.facebook.com/*",
        "https://adsmanager.facebook.com/*",
        "https://www.linkedin.com/campaignmanager/*",
        "http://localhost/*",
        "http://127.0.0.1/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
    {
      "resources": ["panel.html", "panel.css", "panel.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
