{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "routes": [
    {
      "src": "/admin",
      "dest": "/api/admin/page?path=index.html"
    },
    {
      "src": "/admin/",
      "dest": "/api/admin/page?path=index.html"
    },
    {
      "src": "/admin/(.*)",
      "dest": "/api/admin/page?path=$1"
    },
    {
      "src": "/",
      "dest": "/index.html"
    }
  ]
}
